# Meridian API — environment variable template
# Copy to .env.local and fill in real values. Never commit .env.local.
# See docs/SECRETS_POLICY.md for secret handling policy.
#
# Validated by src/config/env.ts (zod schema). The app will fail to
# start if required vars are missing or malformed.

# Railway PostgreSQL connection (required — no default)
DATABASE_URL=postgresql://user:password@host:port/database

# Node.js runtime (optional — defaults shown)
NODE_ENV=development
PORT=3000
